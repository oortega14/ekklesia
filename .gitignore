# ignore docs for claude
docs
.worktrees

# ======= Frontend Ignore =======

# v0 sandbox internal files
/ekklesia-client/__v0_runtime_loader.js
/ekklesia-client/__v0_devtools.tsx
/ekklesia-client/__v0_jsx-dev-runtime.ts
/ekklesia-client/.snowflake/
/ekklesia-client/.v0-trash/
/ekklesia-client/.vercel/
/ekklesia-client/next.user-config.*

# Environment variables
/ekklesia-client/.env*.local
/ekklesia-client/.env
/ekklesia-client/.env.example

# Common ignores
/ekklesia-client/node_modules
/ekklesia-client/.next/
/ekklesia-client/.DS_Store

# TanStack Router generated file
/ekklesia-client/src/routeTree.gen.ts

# ====== Backend Ignore ======

# See https://help.github.com/articles/ignoring-files for more about ignoring files.
#
# Temporary files generated by your text editor or operating system
# belong in git's global ignore instead:
# `$XDG_CONFIG_HOME/git/ignore` or `~/.config/git/ignore`

# Ignore bundler config.
/ekklesia-api/.bundle

# Ignore all environment files.
/ekklesia-api/.env*

# Ignore all logfiles and tempfiles.
/ekklesia-api/log/*
/ekklesia-api/tmp/*
!/ekklesia-api/log/.keep
!/ekklesia-api/tmp/.keep

# Ignore pidfiles, but keep the directory.
/ekklesia-api/tmp/pids/*
!/ekklesia-api/tmp/pids/
!/ekklesia-api/tmp/pids/.keep

# Ignore storage (uploaded files in development and any SQLite databases).
/ekklesia-api/storage/*
!/ekklesia-api/storage/.keep
/ekklesia-api/tmp/storage/*
!/ekklesia-api/tmp/storage/
!/ekklesia-api/tmp/storage/.keep

# Ignore key files for decrypting credentials and more.
/ekklesia-api/config/*.key

